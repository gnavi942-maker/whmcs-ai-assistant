# API Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Security & Authentication
JWT_SECRET_KEY=supersecretjwtkeyforwhmcsmodulesaiassistantpro
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration
# Fallback to local SQLite if POSTGRES_URL is not set or empty
DATABASE_URL=sqlite:///./whmcs_ai.db
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/whmcs_ai

# Redis Configuration (Optional, fallback to in-memory if connection fails)
REDIS_URL=redis://localhost:6379/0

# AI Models Credentials
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Default Model Selection (openai, gemini, anthropic, ollama)
LLM_PROVIDER=gemini
MODEL_NAME=gemini-1.5-pro

# RAG & Embeddings
EMBEDDING_PROVIDER=openai # openai or sentence-transformers
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
VECTOR_DB=chroma # chroma or faiss
CHROMA_DB_PATH=./chroma_db

# Scraper Settings
SCRAPING_INTERVAL_HOURS=24
SCRAPER_TARGET_URL=https://whmcsmodules.org/
CRAWL_DELAY_SECONDS=2
